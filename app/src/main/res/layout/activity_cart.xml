<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_page">

    <!-- Gradient Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:background="@drawable/bg_gradient_header"
        android:elevation="4dp">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/back"
            android:padding="2dp"
            android:contentDescription="Quay lại" />

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Giỏ hàng"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:gravity="center" />

        <View
            android:layout_width="28dp"
            android:layout_height="28dp" />
    </LinearLayout>

    <!-- EMPTY STATE -->
    <LinearLayout
        android:id="@+id/viewEmpty"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="24dp"
        android:visibility="visible">

        <ImageView
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:src="@drawable/v2"
            android:alpha="0.3"
            android:contentDescription="Giỏ trống" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Giỏ hàng trống"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/text_hint" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Hãy thêm món từ menu nhé!"
            android:textSize="14sp"
            android:textColor="@color/text_disabled" />
    </LinearLayout>

    <!-- LIST -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvCart"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="10dp"
        android:clipToPadding="false"
        android:scrollbars="none"
        android:visibility="gone" />

    <!-- FOOTER -->
    <LinearLayout
        android:id="@+id/footerBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="14dp"
        android:paddingBottom="16dp"
        android:background="@drawable/bg_footer_rounded"
        android:elevation="8dp"
        android:visibility="gone">

        <!-- Payment method trigger -->
        <LinearLayout
            android:id="@+id/layoutPaymentTrigger"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:background="@drawable/bg_btn_outline"
            android:onClick="togglePaymentMethod">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="💳 Chọn thanh toán"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary" />

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@android:drawable/ic_menu_more"
                android:contentDescription="Mở" />
        </LinearLayout>

        <!-- Payment method options -->
        <LinearLayout
            android:id="@+id/layoutPaymentMethod"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="8dp">

            <RadioGroup
                android:id="@+id/rgPaymentMethod"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <RadioButton
                    android:id="@+id/rbCash"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="💵 Tiền mặt"
                    android:textSize="14sp"
                    android:padding="6dp"
                    android:buttonTint="@color/primary" />

                <RadioButton
                    android:id="@+id/rbTransfer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="📲 Chuyển khoản"
                    android:textSize="14sp"
                    android:padding="6dp"
                    android:buttonTint="@color/primary" />
            </RadioGroup>
        </LinearLayout>

        <!-- Total + Checkout -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="14dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tổng tiền"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary" />

                <TextView
                    android:id="@+id/tvTotal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 đ"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="@color/accent" />
            </LinearLayout>

            <Button
                android:id="@+id/btnCheckout"
                android:layout_width="180dp"
                android:layout_height="52dp"
                android:text="🛒 Đặt hàng"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:textSize="16sp"
                android:backgroundTint="@color/primary"
                android:textColor="@color/white"
                android:enabled="false"
                android:alpha="0.5" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>