<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:fillViewport="true" android:background="@color/bg_page">

    <LinearLayout
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:padding="16dp">

        <!-- Quick filters -->
        <LinearLayout
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnToday"
                android:layout_width="0dp" android:layout_height="44dp"
                android:layout_weight="1" android:text="Hôm nay"
                android:textAllCaps="false" android:backgroundTint="#FF4D6D"
                android:textColor="@color/white" android:textSize="13sp" />

            <Button
                android:id="@+id/btnThisWeek"
                android:layout_width="0dp" android:layout_height="44dp"
                android:layout_weight="1" android:text="Tuần này"
                android:textAllCaps="false" android:layout_marginStart="6dp"
                android:backgroundTint="@color/primary" android:textColor="#FFFFFF"
                android:textSize="13sp" />

            <Button
                android:id="@+id/btnThisMonth"
                android:layout_width="0dp" android:layout_height="44dp"
                android:layout_weight="1" android:text="Tháng này"
                android:textAllCaps="false" android:layout_marginStart="6dp"
                android:backgroundTint="@color/primary" android:textColor="#FFFFFF"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- Range pickers -->
        <LinearLayout
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginTop="10dp">

            <Button
                android:id="@+id/btnFromDate"
                android:layout_width="0dp" android:layout_height="44dp"
                android:layout_weight="1" android:text="Từ ngày"
                android:textAllCaps="false"
                android:background="@drawable/bg_btn_outline"
                android:textColor="@color/text_secondary" android:textSize="13sp" />

            <Button
                android:id="@+id/btnToDate"
                android:layout_width="0dp" android:layout_height="44dp"
                android:layout_weight="1" android:text="Đến ngày"
                android:textAllCaps="false" android:layout_marginStart="6dp"
                android:background="@drawable/bg_btn_outline"
                android:textColor="@color/text_secondary" android:textSize="13sp" />

            <Button
                android:id="@+id/btnApply"
                android:layout_width="100dp" android:layout_height="44dp"
                android:text="Lọc" android:textAllCaps="false"
                android:layout_marginStart="6dp"
                android:backgroundTint="@color/primary" android:textColor="#FFFFFF"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- Stat Cards -->
        <LinearLayout
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginTop="14dp">

            <!-- Revenue -->
            <LinearLayout
                android:id="@+id/cardRevenue"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical"
                android:padding="14dp"
                android:background="@drawable/bg_card_stat"
                android:elevation="3dp">

                <TextView android:text="Doanh thu" android:textSize="12sp"
                    android:textColor="#9CA3AF" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

                <TextView
                    android:id="@+id/tvRevenue"
                    android:text="0 đ" android:textStyle="bold" android:textSize="20sp"
                    android:textColor="@color/accent" android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp" />
            </LinearLayout>

            <!-- Orders count -->
            <LinearLayout
                android:id="@+id/cardOrders"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical"
                android:padding="14dp"
                android:background="@drawable/bg_card_stat"
                android:elevation="3dp" android:layout_marginStart="8dp">

                <TextView android:text="Số đơn" android:textSize="12sp"
                    android:textColor="#9CA3AF" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

                <TextView
                    android:id="@+id/tvOrderCount"
                    android:text="0" android:textStyle="bold" android:textSize="20sp"
                    android:textColor="@color/accent" android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp" />
            </LinearLayout>

            <!-- Average -->
            <LinearLayout
                android:id="@+id/cardAvg"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical"
                android:padding="14dp"
                android:background="@drawable/bg_card_stat"
                android:elevation="3dp" android:layout_marginStart="8dp">

                <TextView android:text="TB/đơn" android:textSize="12sp"
                    android:textColor="#9CA3AF" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

                <TextView
                    android:id="@+id/tvAvg"
                    android:text="0 đ" android:textStyle="bold" android:textSize="20sp"
                    android:textColor="@color/accent" android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Order list header -->
        <TextView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Danh sách đơn hàng" android:textStyle="bold"
            android:textSize="16sp" android:layout_marginTop="18dp"
            android:textColor="@color/text_primary" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvTopItems"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:paddingTop="8dp" android:clipToPadding="false" />
    </LinearLayout>
</ScrollView>
